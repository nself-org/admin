{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@nself/config Next.js TS config — extends base, adds Next.js plugin + jsx + dom libs",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "preserve",
    "allowJs": true,
    "incremental": true,
    "noEmit": true,
    "plugins": [{ "name": "next" }]
  }
}
