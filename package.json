{
  "name": "nself-admin",
  "version": "1.0.13",
  "private": false,
  "description": "Web-based administration interface for nself CLI backend stack",
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "nself",
    "docker",
    "admin-panel",
    "dashboard",
    "monitoring",
    "container-management",
    "next-js",
    "react",
    "typescript",
    "self-hosted",
    "devops"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nself-org/admin.git"
  },
  "scripts": {
    "dev": "next dev --turbo -p ${PORT:-3021}",
    "build": "next build --webpack",
    "build:analyze": "ANALYZE=true next build --webpack",
    "start": "next start -p ${PORT:-3021}",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --reporters=default --reporters=github-actions",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen http://localhost:3021",
    "test:a11y": "node tests/accessibility/audit.js",
    "test:all": "pnpm test && pnpm test:e2e",
    "docker:build": "docker build -t nself/nself-admin:latest -t nself/nself-admin:$(node -p \"require('./package.json').version\") .",
    "docker:push": "pnpm docker:build && docker push nself/nself-admin:latest && docker push nself/nself-admin:$(node -p \"require('./package.json').version\")",
    "secure:setup": "node scripts/secure-setup.js",
    "password:hash": "node scripts/hash-password.js",
    "docker:release": "./scripts/docker-release.sh",
    "version:bump:patch": "npm version patch --no-git-tag-version",
    "version:bump:minor": "npm version minor --no-git-tag-version",
    "version:bump:major": "npm version major --no-git-tag-version",
    "release": "pnpm build && pnpm docker:push"
  },
  "packageManager": "pnpm@10.28.0",
  "browserslist": "defaults, not ie <= 11",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "sharp",
      "ssh2",
      "cpu-features"
    ],
    "overrides": {
      "tar": ">=7.5.4",
      "fast-xml-parser": ">=5.3.8",
      "basic-ftp": ">=5.2.0",
      "minimatch": ">=9.0.7",
      "@eslint/eslintrc>minimatch": ">=9.0.7",
      "serialize-javascript": ">=7.0.3",
      "dompurify": ">=3.4.0",
      "webpack": ">=5.104.1",
      "protobufjs": ">=7.5.5",
      "lodash": ">=4.18.1"
    }
  },
  "dependencies": {
    "@algolia/autocomplete-core": "^1.19.7",
    "@faker-js/faker": "^10.4.0",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@monaco-editor/react": "^4.7.0",
    "@next/mdx": "^16.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@sentry/nextjs": "^10.49.0",
    "@sindresorhus/slugify": "^2.2.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/bcryptjs": "^2.4.6",
    "@types/dockerode": "^3.3.47",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/lokijs": "^1.5.14",
    "@types/mdx": "^2.0.13",
    "@types/pg": "^8.20.0",
    "@types/react-highlight-words": "^0.20.1",
    "acorn": "^8.16.0",
    "ansi-to-react": "^6.2.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "critters": "^0.0.23",
    "date-fns": "^4.1.0",
    "dockerode": "^4.0.10",
    "dompurify": "^3.4.0",
    "dotenv": "^17.3.1",
    "fast-glob": "^3.3.3",
    "flexsearch": "^0.8.212",
    "framer-motion": "^12.38.0",
    "js-yaml": "^4.1.1",
    "lightningcss": "^1.32.0",
    "lodash": "^4.18.1",
    "lokijs": "^1.5.12",
    "lucide-react": "^0.539.0",
    "mdast-util-to-string": "^4.0.0",
    "mdx-annotations": "^0.1.4",
    "minio": "^8.0.7",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "otplib": "^13.4.0",
    "pg": "^8.20.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-highlight-words": "^0.21.0",
    "react-markdown": "^9.0.1",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "shiki": "^0.14.7",
    "simple-functional-loader": "^1.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "ua-parser-js": "^2.0.9",
    "unist-util-filter": "^5.0.1",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@axe-core/react": "^4.11.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^30.3.0",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/flexsearch": "^0.7.42",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/zxcvbn": "^4.4.5",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "axe-core": "^4.11.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^3.0.1",
    "eventsource": "^4.1.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "sharp": "0.34.3"
  }
}
